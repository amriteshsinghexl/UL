# ULP Backend — environment variable reference
# Copy to .env and adjust values as needed.
# All settings have sensible defaults; only set what you need to override.

# ---------------------------------------------------------
# Server
# ---------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false
RELOAD=false

# ---------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# ---------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---------------------------------------------------------
# Model paths (relative to project root, or absolute)
# ---------------------------------------------------------
DEFAULT_CONFIG_YAML=config.yaml

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
